# Copy this file to `.env` (no .example) and fill in real values.
# `.env` is gitignored — committing it is how secrets leak. NEVER do it.
# `.env.example` IS committed so contributors know what variables are needed.

# --- Postgres (used by docker-compose.yml and, later, the API/worker) ---
POSTGRES_USER=coophub
POSTGRES_PASSWORD=change_me_locally
POSTGRES_DB=coophub
