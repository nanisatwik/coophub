# --- Terraform (Phase 3) ---
# State files contain secrets and infra layout — keep them out of git.
# Real teams store state in S3 + DynamoDB; we'll set that up in Phase 3.
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example

# --- Kubernetes (Phase 4) ---
kubeconfig
*.kubeconfig

